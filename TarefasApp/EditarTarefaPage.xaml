<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TarefasApp.EditarTarefaPage"
             Title="Editar Tarefa"
             Padding="20">

    <ScrollView>
        <StackLayout Spacing="15">
            <Label Text="Título" />
            <Entry x:Name="TituloEntry" />

            <Label Text="Descrição" />
            <Editor x:Name="DescricaoEditor" HeightRequest="100" />

            <Label Text="Data de Criação" />
            <DatePicker x:Name="DataCriacaoPicker" />

            <Label Text="Prioridade" />
            <Picker x:Name="PrioridadePicker">
                <Picker.Items>
                    <x:String>Alta</x:String>
                    <x:String>Média</x:String>
                    <x:String>Baixa</x:String>
                </Picker.Items>
            </Picker>

            <Button Text="Salvar" Clicked="OnSalvarClicked" />
            <Button Text="Cancelar" Clicked="OnCancelarClicked" />
        </StackLayout>
    </ScrollView>
</ContentPage>
