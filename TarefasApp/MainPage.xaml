<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TarefasApp.MainPage"
             Title="Lista de Tarefas">

    <VerticalStackLayout Padding="10" Spacing="10">

        <Button Text="Adicionar Tarefa"
                Clicked="OnAdicionarClicked"
                HorizontalOptions="Center" />

        <CollectionView x:Name="TarefasListView"
                        SelectionMode="Single"
                        SelectionChanged="TarefasListView_SelectionChanged">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BorderColor="LightGray" CornerRadius="8" Padding="10" Margin="5">
                        <VerticalStackLayout>
                            <Label Text="{Binding Titulo}"
                                   FontAttributes="Bold"
                                   FontSize="Medium" />
                            <Label Text="{Binding Descricao}"
                                   FontSize="Small"
                                   TextColor="Gray" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>
