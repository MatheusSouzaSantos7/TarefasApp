<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TarefasApp.PaginaDetalhes"
             Title="Detalhes da Tarefa">

    <ScrollView>
        <StackLayout Padding="20" Spacing="15">
            <Label Text="Título:" FontAttributes="Bold" />
            <Label x:Name="TituloLabel" FontSize="Medium" />

            <Label Text="Descrição:" FontAttributes="Bold" />
            <Label x:Name="DescricaoLabel" FontSize="Medium" />

            <Label Text="Data de Criação:" FontAttributes="Bold" />
            <Label x:Name="DataCriacaoLabel" FontSize="Medium" />

            <Label Text="Prioridade:" FontAttributes="Bold" />
            <Label x:Name="PrioridadeLabel" FontSize="Medium" />

            <Button Text="Editar" Clicked="OnEditarClicked" />
            <Button Text="Excluir" BackgroundColor="Red" TextColor="White" Clicked="OnExcluirClicked"/>
        </StackLayout>
    </ScrollView>
</ContentPage>
